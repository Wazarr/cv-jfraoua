                  <span class="text-code-400">вҖў "What's his ML experience at Qonto?"</span>
                </p>
              </div>
              <div class="flex flex-col sm:flex-row items-start sm:items-center space-y-3 sm:space-y-0 sm:space-x-4 mt-4">
                <a
                  href="/chat"
                  class="bg-primary-600 hover:bg-primary-500 text-white px-8 py-3 rounded-lg font-mono text-sm shadow-lg hover:shadow-xl flex items-center space-x-2"
                >
                  <span>Start a conversation</span>
                  <span aria-hidden="true">вҶ’</span>
                </a>
                <div class="flex items-center space-x-2 text-xs text-light-600 dark:text-dark-400">
                  <div class="w-2 h-2 bg-terminal-500 rounded-full animate-pulse"></div>
                  <span class="font-mono">Powered by LLM guardrails</span>
                </div>
              </div>
            </div>
          </div>
        </TerminalWindow>
      </div>

      <!-- Main Navigation - Modern Cards with Terminal Accents -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 max-w-6xl mx-auto reveal reveal-3">
