---
import Layout from "../layouts/Layout.astro";
import TerminalWindow from "../components/TerminalWindow.astro";
---

<Layout
  title="Projects — Jérémy Fraoua"
  description="AI products built by Jérémy Fraoua: Locaperle (LLM tenant vetting), Saje Editions (RAG reading platform), VibeTrip (AI travel planner), and machine learning projects."
>
  <div class="container mx-auto px-4 py-8 space-y-8">
    <!-- Terminal Header -->
    <TerminalWindow title="my_projects" headerColor="primary" className="max-w-6xl mx-auto">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-terminal-400 hidden md:inline">jeremy@portfolio:~$</span>
          <span class="text-primary-400">portfolio --show-projects</span>
        </div>
        <div class="text-light-700 dark:text-dark-300 pl-4 space-y-1 font-mono text-sm">
          <p class="text-primary-300"># Projects Portfolio</p>
          <p class="text-light-600 dark:text-dark-400"># AI products, machine learning, and full-stack systems</p>
          <p class="text-light-600 dark:text-dark-400"># Focused on practical, user-facing applications</p>
          <div class="mt-3 space-y-1">
            <p><span class="text-terminal-400">project:</span> <span class="text-terminal-400">locaperle</span> <span class="text-light-500 dark:text-dark-500"># LLM-scored tenant vetting SaaS</span></p>
            <p><span class="text-terminal-400">project:</span> <span class="text-primary-400">saje-editions</span> <span class="text-light-500 dark:text-dark-500"># AI reading & publishing platform</span></p>
            <p><span class="text-terminal-400">project:</span> <span class="text-code-400">vibetrip</span> <span class="text-light-500 dark:text-dark-500"># AI travel planning platform</span></p>
            <p><span class="text-terminal-400">project:</span> <span class="text-primary-400">haxball-ai</span> <span class="text-light-500 dark:text-dark-500"># RL environment & training</span></p>
          </div>
        </div>
      </div>
    </TerminalWindow>

    <!-- Featured Project - Locaperle -->
    <TerminalWindow title="locaperle/ --readme" headerColor="terminal" className="max-w-6xl mx-auto relative overflow-hidden before:content-[''] before:absolute before:inset-0 before:bg-gradient-to-br before:from-terminal-500/10 before:via-transparent before:to-primary-500/10 before:opacity-70">
      <div class="space-y-4 relative z-10">
        <div class="space-y-4">
          <div class="flex items-center space-x-4">
            <h2 class="text-3xl font-bold text-terminal-400"># Locaperle</h2>
          </div>
          <p class="text-light-700 dark:text-dark-300 text-lg leading-relaxed">
            AI candidate-triage assistant for landlords re-letting flats: a Chrome extension
            captures messages from rental platforms and Gemini scores each candidate against a
            versioned eligibility rubric, with ready-to-send AI reply drafts.
          </p>

          <div class="grid lg:grid-cols-2 gap-8">
            <div class="space-y-4">
              <div>
                <h3 class="text-lg font-semibold text-terminal-300 mb-3">## Features</h3>
                <ul class="space-y-2 text-light-700 dark:text-dark-300 text-sm">
                  <li class="flex items-start space-x-3">
                    <span class="text-terminal-400 mt-1">-</span>
                    <span>Real-time message capture from LeBonCoin and Gens de Confiance</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-terminal-400 mt-1">-</span>
                    <span>0-100 LLM scoring against versioned rubrics, with input-hash caching</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-terminal-400 mt-1">-</span>
                    <span>Two-pass escalation with extended thinking for unclear cases</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-terminal-400 mt-1">-</span>
                    <span>AI reply drafts (4 archetypes) sent back to the platform via the extension</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="space-y-4">
              <div>
                <h3 class="text-lg font-semibold text-code-300 mb-4">## Tech Stack</h3>
                <div class="space-y-3 text-light-700 dark:text-dark-300 font-mono text-sm">
                  <p><span class="text-code-400">Frontend:</span> React 19, TanStack Router, Tailwind</p>
                  <p><span class="text-terminal-400">Backend:</span> Convex (realtime)</p>
                  <p><span class="text-primary-400">AI:</span> Gemini Flash, Chrome Extension (MV3)</p>
                  <p><span class="text-light-700 dark:text-dark-300">Infra:</span> Vercel, Stripe, Sentry, PostHog</p>
                </div>
              </div>
              <div class="flex space-x-4 pt-4">
                <a
                  href="/projects/locaperle"
                  class="bg-terminal-600 hover:bg-terminal-500 text-white px-4 py-2 rounded-lg font-mono text-sm transition-colors"
                >
                  view details
                </a>
                <a
                  href="https://locaperle.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="bg-light-600 dark:bg-dark-600 hover:bg-light-500 dark:hover:bg-dark-500 text-white px-4 py-2 rounded-lg font-mono text-sm transition-colors"
                >
                  visit app
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </TerminalWindow>

    <!-- Featured Project - Saje Editions -->
    <TerminalWindow title="saje-editions/ --readme" headerColor="primary" className="max-w-6xl mx-auto relative overflow-hidden before:content-[''] before:absolute before:inset-0 before:bg-gradient-to-br before:from-primary-500/10 before:via-transparent before:to-code-500/10 before:opacity-70">
      <div class="space-y-4 relative z-10">
        <div class="space-y-4">
          <div class="flex items-center space-x-4">
            <h2 class="text-3xl font-bold text-primary-400"># Saje Editions</h2>
          </div>
          <p class="text-light-700 dark:text-dark-300 text-lg leading-relaxed">
            AI-powered reading and publishing platform that turns PDF/EPUB libraries into interactive tutors,
            with grounded answers, summaries, and study tools.
          </p>
          
          <div class="grid lg:grid-cols-2 gap-8">
            <div class="space-y-4">
              <div>
                <h3 class="text-lg font-semibold text-primary-300 mb-3">## Features</h3>
                <ul class="space-y-2 text-light-700 dark:text-dark-300 text-sm">
                  <li class="flex items-start space-x-3">
                    <span class="text-primary-400 mt-1">-</span>
                    <span>Chat with books with page-cited answers and streaming responses</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-primary-400 mt-1">-</span>
                    <span>Hybrid retrieval (pgvector + BM25) for accurate grounding</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-primary-400 mt-1">-</span>
                    <span>Summaries, quizzes, and flashcards for study workflows</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="space-y-4">
              <div>
                <h3 class="text-lg font-semibold text-code-300 mb-4">## Tech Stack</h3>
                <div class="space-y-3 text-light-700 dark:text-dark-300 font-mono text-sm">
                  <p><span class="text-code-400">Frontend:</span> Next.js 16, React 19, Tailwind CSS</p>
                  <p><span class="text-terminal-400">Backend:</span> FastAPI, Supabase (Postgres + pgvector)</p>
                  <p><span class="text-primary-400">AI:</span> Gemini via OpenRouter/LiteLLM, Jina reranker</p>
                  <p><span class="text-light-700 dark:text-dark-300">Infra:</span> Railway, Vercel, Stripe</p>
                </div>
              </div>
              <div class="flex space-x-4 pt-4">
                <a 
                  href="/projects/saje-editions"
                  class="bg-primary-600 hover:bg-primary-500 text-white px-4 py-2 rounded-lg font-mono text-sm transition-colors"
                >
                  view details
                </a>
                <a 
                  href="https://sajedition.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="bg-light-600 dark:bg-dark-600 hover:bg-light-500 dark:hover:bg-dark-500 text-white px-4 py-2 rounded-lg font-mono text-sm transition-colors"
                >
                  visit app
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </TerminalWindow>

    <!-- Featured Project - VibeTrip -->
    <TerminalWindow title="vibetrip/ --readme" headerColor="code" className="max-w-6xl mx-auto relative overflow-hidden before:content-[''] before:absolute before:inset-0 before:bg-gradient-to-br before:from-code-500/10 before:via-transparent before:to-terminal-500/10 before:opacity-70">
      <div class="space-y-4 relative z-10">
        <div class="space-y-4">
          <div class="flex items-center space-x-4">
            <h2 class="text-3xl font-bold text-primary-400"># VibeTrip</h2>
          </div>
          <p class="text-light-700 dark:text-dark-300 text-lg leading-relaxed">
            AI travel planner that turns a short onboarding wizard into three complete,
            day-by-day itineraries — accommodations, activities, and timed slots — researched
            live by Gemini with Google Search grounding.
          </p>

          <div class="grid lg:grid-cols-2 gap-8">
            <div class="space-y-4">
              <div>
                <h3 class="text-lg font-semibold text-primary-300 mb-3">## Features</h3>
                <ul class="space-y-2 text-light-700 dark:text-dark-300 text-sm">
                  <li class="flex items-start space-x-3">
                    <span class="text-primary-400 mt-1">-</span>
                    <span>Resumable 7-step trip wizard (group, dates, budget, interests)</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-primary-400 mt-1">-</span>
                    <span>3 complete itineraries per credit, with timed daily slots</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-primary-400 mt-1">-</span>
                    <span>Grounded AI research + pre-seeded knowledge base (~50 destinations)</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-primary-400 mt-1">-</span>
                    <span>Stale-job recovery and auto-refunds on failed generations</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="space-y-4">
              <div>
                <h3 class="text-lg font-semibold text-code-300 mb-4">## Tech Stack</h3>
                <div class="space-y-3 text-light-700 dark:text-dark-300 font-mono text-sm">
                  <p><span class="text-code-400">Frontend:</span> React 19, TanStack Router, Tailwind</p>
                  <p><span class="text-terminal-400">Backend:</span> Convex (realtime)</p>
                  <p><span class="text-primary-400">AI:</span> Gemini Flash + Google Search grounding</p>
                  <p><span class="text-light-700 dark:text-dark-300">Infra:</span> Vercel, Stripe credits, Resend</p>
                </div>
              </div>
              <div class="flex space-x-4 pt-4">
                <a 
                  href="/projects/vibetrip"
                  class="bg-primary-600 hover:bg-primary-500 text-white px-4 py-2 rounded-lg font-mono text-sm transition-colors"
                >
                  view details
                </a>
                <a 
                  href="https://vibetrip.app"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="bg-light-600 dark:bg-dark-600 hover:bg-light-500 dark:hover:bg-dark-500 text-white px-4 py-2 rounded-lg font-mono text-sm transition-colors"
                >
                  visit app
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </TerminalWindow>

    <!-- HaxballGym AI Project -->
    <TerminalWindow title="haxball-ai/ --readme" headerColor="terminal" className="max-w-6xl mx-auto">
      <div class="space-y-4">
        <div class="space-y-4">
          <div class="flex items-center space-x-4">
            <h2 class="text-3xl font-bold text-terminal-400"># HaxballGym</h2>
          </div>
          <p class="text-light-700 dark:text-dark-300 text-lg leading-relaxed">
            Reinforcement Learning environment for training AI agents in the Haxball game. 
            Custom OpenAI Gym environment with reward engineering and agent training pipeline.
          </p>
          
          <div class="grid lg:grid-cols-2 gap-8">
            <div class="space-y-4">
              <div>
                <h3 class="text-lg font-semibold text-terminal-300 mb-3">## Features</h3>
                <ul class="space-y-2 text-light-700 dark:text-dark-300 text-sm">
                  <li class="flex items-start space-x-3">
                    <span class="text-terminal-400 mt-1">-</span>
                    <span>Custom RL environment implementation</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-terminal-400 mt-1">-</span>
                    <span>Agent training and evaluation pipeline</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-terminal-400 mt-1">-</span>
                    <span>Real-time game integration</span>
                  </li>
                  <li class="flex items-start space-x-3">
                    <span class="text-terminal-400 mt-1">-</span>
                    <span>Reward engineering for gameplay optimization</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="space-y-4">
              <div>
                <h3 class="text-lg font-semibold text-code-300 mb-4">## Tech Stack</h3>
                <div class="space-y-3 text-light-700 dark:text-dark-300 font-mono text-sm">
                  <p><span class="text-terminal-400">Language:</span> Python</p>
                  <p><span class="text-code-400">ML Framework:</span> PyTorch</p>
                  <p><span class="text-primary-400">Environment:</span> OpenAI Gym</p>
                  <p><span class="text-light-600 dark:text-dark-400">Training:</span> Reinforcement Learning</p>
                </div>
              </div>
              <div class="flex space-x-4 pt-4">
                <a 
                  href="/projects/haxball-ai"
                  class="bg-terminal-600 hover:bg-terminal-500 text-white px-4 py-2 rounded-lg font-mono text-sm transition-colors"
                >
                  view details
                </a>
                <a 
                  href="https://github.com/Wazarr"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="bg-light-600 dark:bg-dark-600 hover:bg-light-500 dark:hover:bg-dark-500 text-white px-4 py-2 rounded-lg font-mono text-sm transition-colors"
                >
                  open github
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </TerminalWindow>

    <!-- Contact Functions -->
    <TerminalWindow title="contact.sh --collaboration" headerColor="primary" className="max-w-4xl mx-auto">
      <div class="space-y-4">
        <div class="space-y-4">
          <p class="text-light-700 dark:text-dark-300 mb-4">
            Let's discuss potential projects, collaborations, or technical challenges in AI and data science.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a 
              href="mailto:jeremy.fraoua@gmail.com"
              class="block bg-light-300 dark:bg-dark-700 rounded-lg p-4 border border-light-300 dark:border-dark-600 hover:border-primary-500 transition-colors group"
            >
              <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                  <span class="text-primary-400">📧</span>
                  <span class="text-light-800 dark:text-dark-200 font-mono text-sm group-hover:text-primary-400 transition-colors">email me</span>
                </div>
                <span class="text-light-500 dark:text-dark-500 group-hover:text-primary-400 transition-colors">→</span>
              </div>
            </a>
            <a 
              href="https://github.com/Wazarr"
              target="_blank"
              rel="noopener noreferrer"
              class="block bg-light-300 dark:bg-dark-700 rounded-lg p-4 border border-light-300 dark:border-dark-600 hover:border-code-500 transition-colors group"
            >
              <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                  <span class="text-code-400">💻</span>
                  <span class="text-light-800 dark:text-dark-200 font-mono text-sm group-hover:text-code-400 transition-colors">github</span>
                </div>
                <span class="text-light-500 dark:text-dark-500 group-hover:text-code-400 transition-colors">→</span>
              </div>
            </a>
          </div>
        </div>
      </div>
    </TerminalWindow>
  </div>

</Layout>
