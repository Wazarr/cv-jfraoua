---
import Layout from "../layouts/Layout.astro";

const experience = [
  {
    role: "Senior Machine Learning Engineer, Fraud Security Team",
    company: "Qonto",
    location: "Paris",
    period: "Oct. 2024 — Present",
    accent: "primary",
    bullets: [
      "Built fraud detection models with sub-50ms latency, preventing over €100k in fraud",
      "LLM-based alert triage filtering false positives on top of ML models to reduce alert volume",
      "LLM fraud-case classification to build labelled datasets for future model training",
      "Built and shipped an internal frontend tool for the ops team, now fully migrated to production",
    ],
    stack: ["Python", "Machine Learning", "LLMs", "CatBoost", "SQL", "MLOps", "AWS"],
  },
  {
    role: "Quantitative Risk Analyst, Risk Team",
    company: "Qonto",
    location: "Paris",
    period: "Jun. 2023 — Oct. 2024",
    accent: "code",
    bullets: [
      "Established ML development standards adopted across teams: modeling templates and documentation workflows",
      "Developed the German credit risk model from end to end",
      "Assisted multiple departments on data wrangling and dataviz",
    ],
    stack: ["Python", "SQL", "Machine Learning", "Streamlit", "Metabase", "MLOps"],
  },
  {
    role: "Climate Analytics Data Scientist",
    company: "BNP Paribas, Groupe RSE",
    location: "Paris",
    period: "Aug. 2021 — Jun. 2023",
    accent: "terminal",
    bullets: [
      "Built dashboards for portfolio steering and computed net zero targets for the group's alignment report",
      "Assessed climate risks on the electricity generation portfolio",
    ],
    stack: ["R", "Shiny", "Python", "Mathematical modelling"],
  },
  {
    role: "Credit Risk Analyst, RISK Americas",
    company: "BNP Paribas",
    location: "New York",
    period: "2020",
    accent: "terminal",
    bullets: [
      "Analyzed climate change impact on credit risk portfolios",
      "Delivered PG&E bankruptcy case study from California wildfires",
    ],
    stack: ["Python", "Finance", "Geospatial Analysis"],
  },
];

const education = [
  {
    school: "Université Gustave Eiffel",
    degree: "Master in Data and Information Analysis and Management",
    period: "2020 — 2021",
  },
  {
    school: "École des Ponts ParisTech",
    degree: "Master in Mathematics, Finance and Data (Lamberton)",
    period: "2018 — 2020",
  },
  {
    school: "Université Paris-Est Marne-la-Vallée",
    degree: "Degree in Applied Mathematics",
    period: "2015 — 2018",
  },
];

const skills = [
  { label: "Programming", items: "Python, SQL, TypeScript, JavaScript" },
  { label: "Machine Learning", items: "scikit-learn, XGBoost, CatBoost, Hugging Face, LLMs" },
  { label: "MLOps & Data", items: "MLflow, DVC, Kafka, PostgreSQL, Snowflake" },
  { label: "Cloud & DevOps", items: "AWS, Terraform, Kubernetes, Docker, FastAPI" },
  { label: "AI Tools", items: "Claude Code, Cursor, Codex, CrewAI, RAG" },
  { label: "Languages", items: "French (native), English (fluent)" },
];

const accentDot: Record<string, string> = {
  primary: "bg-primary-500",
  code: "bg-code-500",
  terminal: "bg-terminal-500",
};

const accentText: Record<string, string> = {
  primary: "text-primary-400",
  code: "text-code-400",
  terminal: "text-terminal-400",
};
---

<Layout title="Resume - Jérémy Fraoua">
  <div class="container mx-auto px-4 py-10 md:py-16">
    <div class="max-w-3xl mx-auto space-y-14">
      <!-- Header -->
      <header class="text-center space-y-4 reveal">
        <h1 class="text-4xl md:text-5xl font-bold text-light-900 dark:text-dark-100">
          Jérémy Fraoua
        </h1>
        <p class="text-lg md:text-xl text-primary-500 dark:text-primary-400 font-mono">
          Senior Machine Learning Engineer @ Qonto
        </p>
        <p class="text-light-600 dark:text-dark-400 max-w-xl mx-auto">
          Building production fraud and LLM systems that prevented over €100k in fraud.
          I also ship full-stack AI products on the side.
        </p>
        <div class="pt-2">
          <a
            href="/resume_jfraoua.pdf"
            download="Jeremy_Fraoua_Resume.pdf"
            class="inline-flex items-center space-x-2 bg-primary-600 hover:bg-primary-500 text-white px-5 py-2.5 rounded-lg font-mono text-sm transition-colors shadow-lg"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"></path>
            </svg>
            <span>download_pdf()</span>
          </a>
        </div>
      </header>

      <!-- Experience -->
      <section class="space-y-8 reveal reveal-2">
        <div class="flex items-center gap-4">
          <h2 class="font-mono text-sm font-semibold text-primary-500 dark:text-primary-400 tracking-wide">## experience</h2>
          <div class="flex-1 h-px bg-light-300 dark:bg-dark-700"></div>
        </div>

        <ol class="relative border-l border-light-300 dark:border-dark-700 ml-1.5 space-y-10">
          {experience.map((job) => (
            <li class="relative pl-7">
              <span class={`absolute -left-[5.5px] top-1.5 w-2.5 h-2.5 rounded-full ${accentDot[job.accent]} ring-4 ring-light-50 dark:ring-dark-950`} aria-hidden="true"></span>
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1">
                <h3 class="text-base md:text-lg font-semibold text-light-900 dark:text-dark-100">
                  {job.role}
                </h3>
                <p class="font-mono text-xs text-light-500 dark:text-dark-500 whitespace-nowrap md:pl-4">
                  {job.period}
                </p>
              </div>
              <p class={`font-mono text-sm ${accentText[job.accent]} mt-0.5`}>
                {job.company} <span class="text-light-500 dark:text-dark-500">· {job.location}</span>
              </p>
              <ul class="mt-3 space-y-1.5 text-[15px] text-light-700 dark:text-dark-300 leading-relaxed">
                {job.bullets.map((b) => (
                  <li class="flex items-start gap-2.5">
                    <span class={`${accentText[job.accent]} mt-0.5 select-none`} aria-hidden="true">▸</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
              <p class="mt-3 font-mono text-xs text-light-500 dark:text-dark-500">
                {job.stack.join(" · ")}
              </p>
            </li>
          ))}
        </ol>
      </section>

      <!-- Education -->
      <section class="space-y-6 reveal reveal-3">
        <div class="flex items-center gap-4">
          <h2 class="font-mono text-sm font-semibold text-code-500 dark:text-code-400 tracking-wide">## education</h2>
          <div class="flex-1 h-px bg-light-300 dark:bg-dark-700"></div>
        </div>

        <ul class="space-y-4">
          {education.map((edu) => (
            <li class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1">
              <div>
                <h3 class="font-semibold text-light-900 dark:text-dark-100">{edu.school}</h3>
                <p class="text-sm text-light-600 dark:text-dark-400">{edu.degree}</p>
              </div>
              <p class="font-mono text-xs text-light-500 dark:text-dark-500 whitespace-nowrap md:pl-4">
                {edu.period}
              </p>
            </li>
          ))}
        </ul>
      </section>

      <!-- Skills -->
      <section class="space-y-6 reveal reveal-4">
        <div class="flex items-center gap-4">
          <h2 class="font-mono text-sm font-semibold text-terminal-500 dark:text-terminal-400 tracking-wide">## skills</h2>
          <div class="flex-1 h-px bg-light-300 dark:bg-dark-700"></div>
        </div>

        <dl class="grid sm:grid-cols-2 gap-x-10 gap-y-4">
          {skills.map((s) => (
            <div>
              <dt class="font-mono text-xs text-light-500 dark:text-dark-500 uppercase tracking-wider mb-1">
                {s.label}
              </dt>
              <dd class="text-[15px] text-light-700 dark:text-dark-300">{s.items}</dd>
            </div>
          ))}
        </dl>
      </section>

      <!-- Contact -->
      <section class="space-y-6 reveal reveal-4">
        <div class="flex items-center gap-4">
          <h2 class="font-mono text-sm font-semibold text-primary-500 dark:text-primary-400 tracking-wide">## contact</h2>
          <div class="flex-1 h-px bg-light-300 dark:bg-dark-700"></div>
        </div>

        <div class="flex flex-wrap gap-x-8 gap-y-3 font-mono text-sm">
          <a
            href="mailto:jeremy.fraoua@gmail.com"
            class="text-light-700 dark:text-dark-300 hover:text-primary-400 transition-colors"
          >
            <span class="text-primary-400">✉</span> jeremy.fraoua@gmail.com
          </a>
          <a
            href="https://www.linkedin.com/in/jérémy-fraoua/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-light-700 dark:text-dark-300 hover:text-code-400 transition-colors"
          >
            <span class="text-code-400">in</span> linkedin/jérémy-fraoua
          </a>
          <a
            href="https://github.com/Wazarr"
            target="_blank"
            rel="noopener noreferrer"
            class="text-light-700 dark:text-dark-300 hover:text-terminal-400 transition-colors"
          >
            <span class="text-terminal-400">gh</span> github.com/Wazarr
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
